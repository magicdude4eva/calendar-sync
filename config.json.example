{
    "caldav_url": "YOUR_CALDAV_CALENDAR_URL_FROM_MAILBOX_ORG",
    "username": "YOUR_APPLICATION_USERNAME",
    "password": "YOUR_APPLICATION_PASSWORD",
    "timezone": "Europe/Vienna",
    "uid_prefix": "ICS-",
    "future_event_limit_days": 365,
    "extra_events": [
      "☀️ Sommerzeit beginnt:-1.Sunday.3",
      "🌷 Muttertag:2.Sunday.5",
      "👨‍👧‍👦 Vatertag:2.Sunday.6",
      "🔥 Sonnwendfeier:21.6.fixed",
      "🧾 Steuererklärung:30.6.fixed",
      "🌒 Sommerzeit endet:-1.Sunday.10",
      "🎃 Halloween:31.10.fixed",
      "🕯️ 1. Advent:-4.Sunday.12",
      "🕯️ 2. Advent:-3.Sunday.12",
      "🕯️ 3. Advent:-2.Sunday.12",
      "🕯️ 4. Advent:-1.Sunday.12",
      "👹 Krampusnacht:5.12.fixed",
      "🎅 Nikolaus:6.12.fixed"
      ],
    "ics_feeds": [
      {
        "url": "https://app.muellapp.com/ical/74418?area_filter=145382%2C145383%2C151900&reminder&day=1&time=18:00",
        "uid_prefix": "MUELL-",
        "calendar_color": "#D3F4C7",
        "emoji_mapping": {
          "Restmüll": "🗑️",
          "Papier": "♻️",
          "Gelber Sack": "🟡"
        },
        "categories": {
          "append": ["Waste Collection", "Municipal"]
        }
      },
      {
        "url": "https://www.feiertage-oesterreich.at/kalender-download/ics/feiertage-oesterreich.ics",
        "uid_prefix": "HOLIDAY-",
        "import_locations": "K,St",
        "calendar_color": "#FFBDD1",
        "emoji_mapping": {
          "§": "🇦🇹",
          "default": "🗓️"
        },
        "categories": {
          "prepend": ["Austrian"],
          "remove": ["Holiday", "Public"]
        }
      },
      {
        "url": "https://better-f1-calendar.vercel.app/api/calendar.ics",
        "uid_prefix": "F1-",
        "calendar_color": "#BFE9FD",
        "emoji_mapping": {
          " - Practice ": "🏎️",
          "FP1": "🏎️",
          "FP2": "🏎️",
          "FP3": "🏎️",
          "Sprint Qualifying": "⏱️",
          "Sprint": "⚡",
          "Qualifying": "⏱️",
          "Grand Prix": "🏆",
          ": Race": "🏆",
          " - Race": "🏆"
        },
        "categories": {
          "append": ["Sports", "Racing"],
          "remove": ["Event", "Calendar"]
        }
      },
      {
        "url": "https://data.fis-ski.com/services/public/icalendar-feed-fis-events.html?seasoncode=2026&sectorcode=AL&categorycode=WC&gendercode=M",
        "uid_prefix": "FISm-",
        "emoji_mapping": {
          "default": "⛷️ "
        },
        "cleanup_regex": [
          {
            "pattern": "STATUS:FREE",
            "replacement": "STATUS:CONFIRMED"
          }
        ],
        "categories": {
          "replace_if_empty": ["Ski Racing", "FIS"],
          "deduplicate": true
        }
      },
      {
        "url": "https://example.com/tenniscup.ics",
        "uid_prefix": "TENNIS-",
        "emoji_mapping": {
          "default": "🎾"
        },
        "filter": {
          "include": ["Tournament Finals", "Grand Slam"]
        }
      },
      {
        "url": "https://example.com/all-sports.ics",
        "uid_prefix": "SPORTS-",
        "emoji_mapping": {
          "default": "🏅"
        },
        "filter": {
          "exclude": ["Preliminary", "Qualifying", "Practice"]
        }
      },
      {
        "url": "https://example.com/third-party.ics",
        "uid_prefix": "EXAMPLE-",
        "categories": {
          "append": ["Imported"],
          "remove": ["SPAM", "ADVERTISING", "Third-Party"],
          "deduplicate": true
        }
      },
      {
        "url": "https://example.com/empty-categories.ics",
        "uid_prefix": "EMPTY-",
        "categories": {
          "replace_if_empty": ["Default Category"],
          "append": ["Synced Events"]
        }
      }
    ]
  }
